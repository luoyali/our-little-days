    <section class="mt-5 mb-12">
        <div class="flex flex-col gap-6 md:flex-row md:items-center">
            <div class="w-28 shrink-0 md:w-36">
                <Image
                    class="fill-current rounded-ac-lg shadow-ac"
                    format="webp"
                    width={300}
                    height={300}
                    src={url('favicon.svg')}
                    alt="个人头像"
                />
            </div>

            <div class="grow">
                <div class="mb-4">
                    <div class="text-3xl w-full font-bold">关于我</div>
                    <div class="mt-2 h-1 w-20 rounded-full bg-ac-primary"></div>
                </div>

                <div class="flex flex-wrap gap-2">
                    {
                        aboutTags.map((tag) => (
                            <span class="badge badge-outline border-ac-primary text-ac-text">
                                {tag}
                            </span>
                        ))
                    }
                </div>
            </div>
        </div>

        <div class="mt-8 rounded-ac-lg bg-base-100 p-6 shadow-ac border-l-4 border-ac-primary md:p-8">
            <div class="grid gap-5 text-base leading-8 text-ac-text md:text-lg">
                {
                    aboutParagraphs.map((paragraph, index) => (
                        <p class={index === aboutParagraphs.length - 1 ? "font-bold" : ""}>
                            {paragraph}
                        </p>
                    ))
                }
            </div>
        </div>
    </section>

