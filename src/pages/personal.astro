---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import { AUTHOR_INITIAL, url } from "src/config";

const aboutTags = ["双职工宝妈", "互联网工程师", "4岁宝妈", "厨房爱好者", "健身坚持者"];

const aboutParagraphs = [
    "大家好，我是一个普通的双职工宝妈，也是一枚互联网工程师，家里有个活泼可爱的4岁小宝贝。",
    "白天忙工作，晚上回家就是一家三口的温暖小日子。我喜欢周末在厨房尝试自制面包和蛋糕，看着家人吃得开心就觉得满足。健身则是我保持精力的方式，让我在工作和带娃中还能照顾好自己。",
    "生活里的我并不完美，也常常手忙脚乱，但我一直在努力寻找平衡：用心工作、享受家庭，同时把日子过得更从容。",
    "很高兴在这里遇见你，希望我们都能把普通日子过成喜欢的样子。",
];
---

<BaseLayout
    title={AUTHOR_INITIAL + " | Personal"}
    sideBarActiveItemID="personal"
>
